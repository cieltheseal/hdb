    <worksheet name='Resale Prices Map Complete'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontsize='14'>Resale Prices by Area</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='planning_area.geojson+ (Multiple Connections)' name='federated.0k8n5zs12yq2b1119v9ir07rguzw' />
            <datasource name='Parameters' />
          </datasources>
          <mapsources>
            <mapsource name='Tableau' />
          </mapsources>
          <datasource-dependencies datasource='Parameters'>
            <column alias='Median/Average' caption='Select Min, Med, or Max' datatype='string' name='[Parameter 1]' param-domain-type='list' role='measure' type='nominal' value='&quot;Med&quot;'>
              <calculation class='tableau' formula='&quot;Med&quot;' />
              <aliases>
                <alias key='&quot;Max&quot;' value='Maximum' />
                <alias key='&quot;Med&quot;' value='Median/Average' />
                <alias key='&quot;Min&quot;' value='Minimum' />
              </aliases>
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.0k8n5zs12yq2b1119v9ir07rguzw'>
            <column caption='Min, Med, or Max Resale Price' datatype='real' name='[Calculation_1154806437031943]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#13;&#10;  WHEN &apos;Min&apos; THEN MIN([resale_price])&#13;&#10;  WHEN &apos;Med&apos; THEN MEDIAN([resale_price])&#13;&#10;  WHEN &apos;Max&apos; THEN MAX([resale_price])&#13;&#10;END' />
            </column>
            <column caption='Resale Price Z-Score' datatype='real' name='[Calculation_1204009950650370]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(AVG([resale_price]) - WINDOW_AVG(AVG([resale_price]))) / WINDOW_STDEV(AVG([resale_price]))'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column datatype='spatial' name='[Geometry]' role='measure' type='nominal' />
            <column datatype='string' name='[Town]' role='dimension' type='nominal' />
            <column-instance column='[Geometry]' derivation='Collect' name='[clct:Geometry:nk]' pivot='key' type='nominal' />
            <column caption='Flat Type' datatype='string' name='[flat_type]' role='dimension' type='nominal' />
            <column-instance column='[Town]' derivation='None' name='[none:Town:nk]' pivot='key' type='nominal' />
            <column-instance column='[flat_type]' derivation='None' name='[none:flat_type:nk]' pivot='key' type='nominal' />
            <column-instance column='[storey_range]' derivation='None' name='[none:storey_range:nk]' pivot='key' type='nominal' />
            <column-instance column='[year]' derivation='None' name='[none:year:ok]' pivot='key' type='ordinal' />
            <column aggregation='Median' caption='Resale Price' datatype='real' name='[resale_price]' role='measure' type='quantitative' />
            <column caption='Storey Range' datatype='string' name='[storey_range]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_1154806437031943]' derivation='User' name='[usr:Calculation_1154806437031943:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_1204009950650370]' derivation='User' name='[usr:Calculation_1204009950650370:qk:2]' pivot='key' type='quantitative'>
              <table-calc ordering-field='[federated.0k8n5zs12yq2b1119v9ir07rguzw].[Town]' ordering-type='Field' />
            </column-instance>
            <column caption='Resale Year' datatype='integer' name='[year]' role='dimension' type='ordinal' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.0k8n5zs12yq2b1119v9ir07rguzw].[Action (Flat Type)]'>
            <groupfilter function='level-members' level='[flat_type]' user:ui-action-filter='[Action4_4FE244BF7DCA4CDFB99156D6F2C2AE59]' user:ui-enumeration='all' user:ui-marker='enumerate' />
