            <column caption='Global Type' datatype='string' name='[Room Type Parameter]' param-domain-type='list' role='measure' type='nominal' value='&quot;All&quot;'>
              <calculation class='tableau' formula='&quot;All&quot;' />
            </column>
            <column caption='Global Year' datatype='integer' name='[Year Parameter]' param-domain-type='range' role='measure' type='quantitative' value='2008'>
              <calculation class='tableau' formula='2008' />
              <range max='2024' min='2008' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.0k8n5zs12yq2b1119v9ir07rguzw'>
            <column caption='Year Match (Resale)' datatype='boolean' name='[Calculation_1154806401478656]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[year] = [Parameters].[Year Parameter]' />
            </column>
            <column caption='Type Match (Resale)' datatype='boolean' name='[Calculation_1154806422523909]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [Parameters].[Room Type Parameter] = &quot;All&quot; THEN TRUE&#13;&#10;ELSE [flat_type] = [Parameters].[Room Type Parameter]&#13;&#10;END' />
            </column>
            <column caption='Min, Med, or Max Resale Price' datatype='real' name='[Calculation_1154806437031943]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#13;&#10;  WHEN &apos;Min&apos; THEN MIN([resale_price])&#13;&#10;  WHEN &apos;Med&apos; THEN MEDIAN([resale_price])&#13;&#10;  WHEN &apos;Max&apos; THEN MAX([resale_price])&#13;&#10;END' />
            </column>
