            </column>
            <column caption='Global Type' datatype='string' name='[Room Type Parameter]' param-domain-type='list' role='measure' type='nominal' value='&quot;3-room&quot;'>
              <calculation class='tableau' formula='&quot;3-room&quot;' />
            </column>
            <column caption='Global Year' datatype='integer' name='[Year Parameter]' param-domain-type='range' role='measure' type='quantitative' value='2009'>
              <calculation class='tableau' formula='2009' />
              <range max='2024' min='2008' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.0k8n5zs12yq2b1119v9ir07rguzw'>
            <column caption='Year Match (Resale)' datatype='boolean' name='[Calculation_1154806401478656]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[year] = [Parameters].[Year Parameter]' />
