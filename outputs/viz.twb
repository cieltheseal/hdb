      <aliases enabled='yes' />
      <column datatype='string' name='[:Measure Names]' role='dimension' type='nominal'>
        <aliases>
          <alias key='&quot;[federated.0k8n5zs12yq2b1119v9ir07rguzw].[max:max_selling_price_less_ahg_shg:qk]&quot;' value='Max Price With Grants' />
          <alias key='&quot;[federated.0k8n5zs12yq2b1119v9ir07rguzw].[max:max_selling_price:qk]&quot;' value='Max Price' />
          <alias key='&quot;[federated.0k8n5zs12yq2b1119v9ir07rguzw].[med:resale_price:qk]&quot;' value='Med. Resale Price' />
          <alias key='&quot;[federated.0k8n5zs12yq2b1119v9ir07rguzw].[min:min_selling_price_less_ahg_shg:qk]&quot;' value='Min Price With Grants' />
          <alias key='&quot;[federated.0k8n5zs12yq2b1119v9ir07rguzw].[min:min_selling_price:qk]&quot;' value='Min Price' />
        </aliases>
      </column>
      <column caption='Year Match (Resale)' datatype='boolean' name='[Calculation_1154806401478656]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[year] = [Parameters].[Year Parameter]' />
      </column>
      <column caption='Year Match (BTO)' datatype='boolean' name='[Calculation_1154806401662977]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[financial_year] = [Parameters].[Year Parameter]' />
      </column>
      <column caption='Town Match (Resale)' datatype='boolean' name='[Calculation_1154806421843970]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[town] = [Parameters].[Town Parameter]' />
      </column>
      <column caption='Town Match (BTO)' datatype='boolean' name='[Calculation_1154806422183939]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[town (bto_price.csv)] = [Parameters].[Town Parameter]' />
      </column>
      <column caption='Type Match (BTO)' datatype='boolean' name='[Calculation_1154806422413316]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Parameters].[Room Type Parameter] = &quot;All&quot; THEN TRUE&#13;&#10;ELSE [room_type] = [Parameters].[Room Type Parameter]&#13;&#10;END' />
      </column>
      <column caption='Type Match (Resale)' datatype='boolean' name='[Calculation_1154806422523909]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Parameters].[Room Type Parameter] = &quot;All&quot; THEN TRUE&#13;&#10;ELSE [flat_type] = [Parameters].[Room Type Parameter]&#13;&#10;END' />
      </column>
      <column caption='Min, Med, or Max Resale Price' datatype='real' name='[Calculation_1154806437031943]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#13;&#10;  WHEN &apos;Min&apos; THEN MIN([resale_price])&#13;&#10;  WHEN &apos;Med&apos; THEN MEDIAN([resale_price])&#13;&#10;  WHEN &apos;Max&apos; THEN MAX([resale_price])&#13;&#10;END' />
      </column>
      <column aggregation='Avg' caption='Mid Selling Price' datatype='real' name='[Calculation_1154806454718480]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([min_selling_price]+[max_selling_price])/2' />
      </column>
      <column caption='Variable Selling Price' datatype='real' name='[Calculation_1154806455091217]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#13;&#10;  WHEN &apos;Min&apos; THEN [min_selling_price]&#13;&#10;  WHEN &apos;Med&apos;  THEN [Calculation_1154806454718480]&#13;&#10;  WHEN &apos;Max&apos; THEN [max_selling_price]&#13;&#10;END' />
      </column>
      <column caption='MMM Selector' datatype='string' name='[Calculation_1154806463152147]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='// This creates a list of your three options&#13;&#10;IF [resale_price] &gt; 1000000 THEN &apos;Min&apos; &#13;&#10;ELSEIF [resale_price] &gt; 500000 THEN &apos;Med&apos; &#13;&#10;ELSE &apos;Max&apos; &#13;&#10;END' />
      </column>
      <column caption='MMM Active' datatype='boolean' name='[Calculation_1154806464634900]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Calculation_1154806463152147] = [Parameters].[Parameter 1]' />
      </column>
      <column caption='Condensed Flat Type' datatype='string' name='[Calculation_1204009899151361]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [flat_type] = &quot;1-room&quot; OR [flat_type] = &quot;2-room&quot; OR [flat_type] = &quot;Multi-generation&quot; &#13;&#10;THEN &quot;Other&quot; &#13;&#10;ELSE [flat_type] &#13;&#10;END' />
      </column>
      <column caption='Resale Price Z-Score' datatype='real' name='[Calculation_1204009950650370]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(AVG([resale_price]) - WINDOW_AVG(AVG([resale_price]))) / WINDOW_STDEV(AVG([resale_price]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='BTO Price Z-Score' datatype='real' name='[Calculation_1204010027081733]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(AVG([Calculation_1154806454718480]) - WINDOW_AVG(AVG([Calculation_1154806454718480]))) / WINDOW_STDEV(AVG([Calculation_1154806454718480]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Base 2026 CPI' datatype='real' name='[Calculation_1649862250422272]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED : MAX(IF [Year] = 2026 THEN [Overall] END) }' />
      </column>
      <column caption='Adjusted Resale Price' datatype='real' name='[Calculation_1649862252154881]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[resale_price] * ([Calculation_1649862250422272] / [Overall])' />
      </column>
