      </column>
      <column caption='Type Match (BTO)' datatype='boolean' name='[Calculation_1154806422413316]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[room_type] = [Parameters].[Room Type Parameter]' />
      </column>
      <column caption='Type Match (Resale)' datatype='boolean' name='[Calculation_1154806422523909]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[flat_type] = [Parameters].[Room Type Parameter]' />
      </column>
      <column caption='Min, Med, or Max Resale Price' datatype='real' name='[Calculation_1154806437031943]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#13;&#10;  WHEN &apos;Min&apos; THEN MIN([resale_price])&#13;&#10;  WHEN &apos;Med&apos; THEN MEDIAN([resale_price])&#13;&#10;  WHEN &apos;Max&apos; THEN MAX([resale_price])&#13;&#10;END' />
      </column>
      <column aggregation='Max' caption='Yearly Max Global Price' datatype='real' name='[Calculation_1154806446616587]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MAX(&#13;&#10;  { FIXED [Parameters].[Year Parameter] : MAX([resale_price]) }, &#13;&#10;  { FIXED [Parameters].[Year Parameter] : MAX([max_selling_price]) }&#13;&#10;)' />
      </column>
      <column aggregation='Min' caption='Yearly Min Global Price' datatype='real' name='[Calculation_1154806446960652]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MIN(&#13;&#10;  { FIXED [Parameters].[Year Parameter] : MIN([resale_price]) }, &#13;&#10;  { FIXED [Parameters].[Year Parameter] : MIN([min_selling_price]) }&#13;&#10;)' />
      </column>
      <column aggregation='Median' caption='Color Driver (Resale)' datatype='real' name='[Calculation_1154806447308813]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([resale_price] - [Calculation_1154806446960652]) / ([Calculation_1154806446616587] - [Calculation_1154806446960652])' />
      </column>
      <column caption='Color Driver (BTO Min)' datatype='real' name='[Calculation_1154806447468558]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([min_selling_price] - [Calculation_1154806446960652]) / ([Calculation_1154806446616587] - [Calculation_1154806446960652])' />
      </column>
      <column aggregation='Max' caption='Color Driver (BTO Max)' datatype='real' name='[Calculation_1154806447583247]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([max_selling_price] - [Calculation_1154806446960652]) / ([Calculation_1154806446616587] - [Calculation_1154806446960652])' />
      </column>
      <column caption='Mid Selling Price' datatype='real' name='[Calculation_1154806454718480]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([min_selling_price]+[max_selling_price])/2' />
      </column>
      <column caption='Variable Selling Price' datatype='real' name='[Calculation_1154806455091217]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#13;&#10;  WHEN &apos;Min&apos; THEN [min_selling_price]&#13;&#10;  WHEN &apos;Med&apos;  THEN [Calculation_1154806454718480]&#13;&#10;  WHEN &apos;Max&apos; THEN [max_selling_price]&#13;&#10;END' />
      </column>
      <column caption='MMM Selector' datatype='string' name='[Calculation_1154806463152147]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='// This creates a list of your three options&#13;&#10;IF [resale_price] &gt; 1000000 THEN &apos;Min&apos; &#13;&#10;ELSEIF [resale_price] &gt; 500000 THEN &apos;Med&apos; &#13;&#10;ELSE &apos;Max&apos; &#13;&#10;END' />
      </column>
      <column caption='MMM Active' datatype='boolean' name='[Calculation_1154806464634900]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Calculation_1154806463152147] = [Parameters].[Parameter 1]' />
      </column>
      <column caption='Condensed Flat Type' datatype='string' name='[Calculation_1204009899151361]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [flat_type] = &quot;1-room&quot; OR [flat_type] = &quot;2-room&quot; OR [flat_type] = &quot;Multi-generation&quot; &#13;&#10;THEN &quot;Other&quot; &#13;&#10;ELSE [flat_type] &#13;&#10;END' />
      </column>
      <column caption='Price Z-Score' datatype='real' name='[Calculation_1204009950650370]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(AVG([resale_price]) - WINDOW_AVG(AVG([resale_price]))) / WINDOW_STDEV(AVG([resale_price]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
