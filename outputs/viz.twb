      <column caption='Year Match (Resale)' datatype='boolean' name='[Calculation_1154806401478656]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[year] = [Parameters].[Year Parameter]' />
      </column>
      <column caption='Year Match (BTO)' datatype='boolean' name='[Calculation_1154806401662977]' role='dimension' type='nominal'>
