      <table>
        <view>
          <datasources>
            <datasource caption='planning_area.geojson+ (Multiple Connections)' name='federated.0k8n5zs12yq2b1119v9ir07rguzw' />
            <datasource name='Parameters' />
          </datasources>
          <mapsources>
            <mapsource name='Tableau' />
          </mapsources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Select Min, Med, or Max' datatype='string' name='[Parameter 1]' param-domain-type='list' role='measure' type='nominal' value='&quot;Med&quot;'>
              <calculation class='tableau' formula='&quot;Med&quot;' />
            </column>
            <column caption='Global Type' datatype='string' name='[Room Type Parameter]' param-domain-type='list' role='measure' type='nominal' value='&quot;3-room&quot;'>
              <calculation class='tableau' formula='&quot;3-room&quot;' />
            </column>
            <column caption='Global Year' datatype='integer' name='[Year Parameter]' param-domain-type='range' role='measure' type='quantitative' value='2008'>
              <calculation class='tableau' formula='2008' />
              <range max='2024' min='2008' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.0k8n5zs12yq2b1119v9ir07rguzw'>
            <column caption='Year Match (BTO)' datatype='boolean' name='[Calculation_1154806401662977]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[financial_year] = [Parameters].[Year Parameter]' />
            </column>
            <column caption='Type Match (BTO)' datatype='boolean' name='[Calculation_1154806422413316]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[room_type] = [Parameters].[Room Type Parameter]' />
            </column>
            <column aggregation='Avg' caption='Mid Selling Price' datatype='real' name='[Calculation_1154806454718480]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='([min_selling_price]+[max_selling_price])/2' />
            </column>
            <column caption='Variable Selling Price' datatype='real' name='[Calculation_1154806455091217]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='CASE [Parameters].[Parameter 1]&#13;&#10;  WHEN &apos;Min&apos; THEN [min_selling_price]&#13;&#10;  WHEN &apos;Med&apos;  THEN [Calculation_1154806454718480]&#13;&#10;  WHEN &apos;Max&apos; THEN [max_selling_price]&#13;&#10;END' />
            </column>
            <column datatype='spatial' name='[Geometry]' role='measure' type='nominal' />
            <column datatype='string' name='[Town]' role='dimension' type='nominal' />
            <column-instance column='[Geometry]' derivation='Collect' name='[clct:Geometry:nk]' pivot='key' type='nominal' />
            <column caption='Financial Year' datatype='integer' name='[financial_year]' role='dimension' type='ordinal' />
            <column aggregation='Max' caption='Max Selling Price' datatype='real' name='[max_selling_price]' role='measure' type='quantitative' />
            <column aggregation='Min' caption='Min Selling Price' datatype='real' name='[min_selling_price]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_1154806401662977]' derivation='None' name='[none:Calculation_1154806401662977:nk]' pivot='key' type='nominal' />
            <column-instance column='[Calculation_1154806422413316]' derivation='None' name='[none:Calculation_1154806422413316:nk]' pivot='key' type='nominal' />
            <column-instance column='[Town]' derivation='None' name='[none:Town:nk]' pivot='key' type='nominal' />
            <column caption='Room Type' datatype='string' name='[room_type]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_1154806455091217]' derivation='Sum' name='[sum:Calculation_1154806455091217:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
