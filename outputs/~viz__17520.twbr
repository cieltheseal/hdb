    <worksheet name='BTO Prices Map (Solo)'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontsize='14'>&lt;Sheet Name&gt;</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='planning_area.geojson+ (Multiple Connections)' name='federated.0k8n5zs12yq2b1119v9ir07rguzw' />
          </datasources>
          <mapsources>
            <mapsource name='Tableau' />
          </mapsources>
          <datasource-dependencies datasource='federated.0k8n5zs12yq2b1119v9ir07rguzw'>
            <column aggregation='Avg' caption='Mid Selling Price' datatype='real' name='[Calculation_1154806454718480]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='([min_selling_price]+[max_selling_price])/2' />
            </column>
            <column caption='BTO Price Z-Score' datatype='real' name='[Calculation_1204010027081733]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(AVG([Calculation_1154806454718480]) - WINDOW_AVG(AVG([Calculation_1154806454718480]))) / WINDOW_STDEV(AVG([Calculation_1154806454718480]))'>
                <table-calc ordering-type='Rows' />
              </calculation>
            </column>
            <column datatype='spatial' name='[Geometry]' role='measure' type='nominal' />
            <column datatype='string' name='[Town]' role='dimension' type='nominal' />
            <column-instance column='[Calculation_1154806454718480]' derivation='Avg' name='[avg:Calculation_1154806454718480:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Geometry]' derivation='Collect' name='[clct:Geometry:nk]' pivot='key' type='nominal' />
